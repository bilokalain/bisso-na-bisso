generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  nom       String
  email     String    @unique
  telephone String?
  ville     String?
  role      Role      @default(USER)
  createdAt DateTime  @default(now())
  annonces  Annonce[]
}

model Annonce {
  id          String   @id @default(cuid())
  type        String   // "evenementiel" | "colis" | "repetiteur"
  titre       String
  slug        String   @unique
  description String
  ville       String?
  photos      String[] @default([]) // Liste d'URLs (Vercel Blob) — photos[0] = principale
  prix        Float?
  devise      String   @default("EUR")

  // Événementiel
  categorie String? // coiffure, traiteur, dj, photo, video, decoration, salle, brasseur...

  // Colis (voyage)
  villeDepart  String?
  villeArrivee String?
  dateVoyage   DateTime?
  kgDispo      Float?
  prixParKg    Float?

  // Répétiteur
  matiere  String? // maths, francais, neerlandais, anglais, chimie, physique...
  niveau   String? // primaire, secondaire, superieur
  modalite String? // en_ligne, presentiel, les_deux

  // Contact direct (MVP simple sans messagerie interne)
  contactNom       String
  contactTelephone String
  contactEmail     String?

  status    Status   @default(ACTIVE)
  expiresAt DateTime

  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([ville])
  @@index([categorie])
  @@index([status])
  @@index([expiresAt])
}

enum Role {
  USER
  ADMIN
}

enum Status {
  ACTIVE
  ARCHIVED
  REJECTED
}

model Module {
  id        String       @id @default(cuid())
  key       String       @unique
  label     String
  tagline   String
  status    ModuleStatus @default(DISABLED)
  order     Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  interests ModuleInterest[]

  @@index([status])
  @@index([order])
}

enum ModuleStatus {
  ENABLED
  COMING_SOON
  DISABLED
}

model ModuleInterest {
  id        String   @id @default(cuid())
  moduleId  String
  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  email     String
  createdAt DateTime @default(now())

  @@unique([moduleId, email])
  @@index([moduleId])
}

model Guide {
  id             String       @id @default(cuid())
  slug           String       @unique
  title          String
  tldr           String       // short summary shown on cards and top of detail
  content        String       // Markdown body
  category       String       // fiscalite | famille | logement | citoyennete | etudiant
  heroImage      String?
  readingMinutes Int          @default(5)
  authorName     String?
  status         GuideStatus  @default(DRAFT)
  publishedAt    DateTime?
  lastReviewedAt DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([status])
  @@index([category])
  @@index([publishedAt])
}

enum GuideStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Basket {
  id          String       @id @default(cuid())
  slug        String       @unique
  name        String                          // "Panier Famille"
  tagline     String                          // "Nourrir 5 personnes pendant 2 semaines"
  heroImage   String?
  destination String                          // "kinshasa" for MVP
  priceEUR    Int                             // TTC, centimes
  active      Boolean      @default(true)
  order       Int          @default(0)
  items       BasketItem[]
  orders      Order[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([destination])
  @@index([active])
}

model BasketItem {
  id        String  @id @default(cuid())
  basketId  String
  basket    Basket  @relation(fields: [basketId], references: [id], onDelete: Cascade)
  name      String
  quantity  String                            // "5 kg", "4×5 L", etc.
  order     Int     @default(0)

  @@index([basketId])
}

model Order {
  id               String        @id @default(cuid())
  reference        String        @unique      // BNB-A4F7X2, visible côté client
  basketId         String
  basket           Basket        @relation(fields: [basketId], references: [id])

  // Expéditeur (diaspora)
  senderName       String
  senderEmail      String
  senderPhone      String?

  // Destinataire (Kinshasa)
  recipientName    String
  recipientPhone   String
  recipientAddress String
  recipientNotes   String?                    // repères, indications

  // Le mot lu à la livraison
  messageToFamily  String?

  // Paiement
  amountEUR        Int
  paymentStatus    PaymentStatus @default(PENDING)
  stripeSessionId  String?

  // Fulfillment
  status           OrderStatus   @default(RECEIVED)
  confirmedAt      DateTime?                  // Maman a confirmé son adresse
  dispatchedAt     DateTime?                  // partenaire en route
  deliveredAt      DateTime?
  deliveryPhotoUrl String?
  deliveryVideoUrl String?

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([paymentStatus])
  @@index([status])
  @@index([senderEmail])
  @@index([createdAt])
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum OrderStatus {
  RECEIVED
  CONFIRMED
  DISPATCHED
  DELIVERED
  ISSUE
  CANCELED
}
