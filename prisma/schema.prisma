generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String    @id @default(cuid())
  nom       String
  email     String    @unique
  telephone String?
  ville     String?
  role      Role      @default(USER)
  createdAt DateTime  @default(now())
  annonces  Annonce[]
}

model Annonce {
  id          String   @id @default(cuid())
  type        String   // "evenementiel" | "colis" | "repetiteur"
  titre       String
  slug        String   @unique
  description String
  ville       String?
  photo       String?  // URL image
  prix        Float?
  devise      String   @default("EUR")

  // Événementiel
  categorie String? // coiffure, traiteur, dj, photo, video, decoration, salle, brasseur...

  // Colis (voyage)
  villeDepart  String?
  villeArrivee String?
  dateVoyage   DateTime?
  kgDispo      Float?
  prixParKg    Float?

  // Répétiteur
  matiere  String? // maths, francais, neerlandais, anglais, chimie, physique...
  niveau   String? // primaire, secondaire, superieur
  modalite String? // en_ligne, presentiel, les_deux

  // Contact direct (MVP simple sans messagerie interne)
  contactNom       String
  contactTelephone String
  contactEmail     String?

  status    Status   @default(ACTIVE)
  expiresAt DateTime

  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([ville])
  @@index([categorie])
  @@index([status])
  @@index([expiresAt])
}

enum Role {
  USER
  ADMIN
}

enum Status {
  ACTIVE
  ARCHIVED
  REJECTED
}

model Module {
  id        String       @id @default(cuid())
  key       String       @unique
  label     String
  tagline   String
  status    ModuleStatus @default(DISABLED)
  order     Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  interests ModuleInterest[]

  @@index([status])
  @@index([order])
}

enum ModuleStatus {
  ENABLED
  COMING_SOON
  DISABLED
}

model ModuleInterest {
  id        String   @id @default(cuid())
  moduleId  String
  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  email     String
  createdAt DateTime @default(now())

  @@unique([moduleId, email])
  @@index([moduleId])
}

model Guide {
  id             String       @id @default(cuid())
  slug           String       @unique
  title          String
  tldr           String       // short summary shown on cards and top of detail
  content        String       // Markdown body
  category       String       // fiscalite | famille | logement | citoyennete | etudiant
  heroImage      String?
  readingMinutes Int          @default(5)
  authorName     String?
  status         GuideStatus  @default(DRAFT)
  publishedAt    DateTime?
  lastReviewedAt DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([status])
  @@index([category])
  @@index([publishedAt])
}

enum GuideStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}
